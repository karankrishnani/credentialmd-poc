# EverCred POC Environment Configuration

# Mock Mode (default: true)
# When true: uses mock data providers, no external API calls needed
# When false: uses live APIs (NPI, DCA Playwright, Claude)
EVERCRED_MOCK_MODE=true

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=3000

# Database path (relative to backend/)
DUCKDB_PATH=../data/evercred.duckdb

# LEIE CSV path (relative to backend/)
# Use UPDATED_test.csv for mock mode, UPDATED.csv for live mode
LEIE_CSV_PATH=../data/UPDATED_test.csv

# DCA scraper: headed Chrome (visible browser) for debugging Turnstile/CAPTCHA
# Set to false for headless (faster, but may be blocked by CAPTCHA)
DCA_HEADED=true

# DCA scraper: retries on failure (default 0 to avoid rate limits/bans)
# DCA_MAX_RETRIES=0

# DCA scraper: use existing Chrome profile (bypasses Turnstile better)
# Close Chrome first. Paths: macOS ~/Library/Application Support/Google/Chrome
# Linux ~/.config/google-chrome  Windows %LOCALAPPDATA%\Google\Chrome\User Data
# DCA_CHROME_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
